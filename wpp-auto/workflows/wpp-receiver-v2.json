      "id": "b0000001-0000-0000-0000-000000000020",
      "name": "Redis: limpar buffer",
      "type": "n8n-nodes-base.redis",
      "typeVersion": 1,
      "position": [3280, 620],
      "credentials": {"redis": {"id": "YEun9v2RmIsI97HG", "name": "Redis account"}}
