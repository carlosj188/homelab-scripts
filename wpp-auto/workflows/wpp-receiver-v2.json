    {
      "parameters": {
        "jsCode": "// Lógica inteligente: procura dígito válido (0/1/2/3) nas mensagens da rajada\n// Se achar, usa o dígito. Se não, concatena tudo pro bot mandar msg de erro.\n\nconst contactNumber = $('Preparar buffer keys').item.json.contact_number;\nconst instance = $('Preparar buffer keys').item.json.instance;\nconst messageId = $('Preparar buffer keys').item.json.message_id;\n\n// O node 'Redis: ler buffer' retorna um objeto cuja chave é o nome da chave Redis\n// e o valor é o array de mensagens. Vamos extrair o array.\nconst previousOutput = $input.first().json;\nlet messages = [];\n\n// Tenta extrair o array de mensagens - pode vir em formatos diferentes\nfor (const key in previousOutput) {\n  if (Array.isArray(previousOutput[key])) {\n    messages = previousOutput[key];\n    break;\n  }\n}\n\n// Se não achou array, tenta usar o content direto (fallback)\nif (messages.length === 0) {\n  const fallback = $('Preparar buffer keys').item.json.content;\n  if (fallback) messages = [fallback];\n}\n\n// Procura dígito válido em qualquer mensagem\n// Aceita: \"1\", \" 1 \", \"1.\", \"1)\", \"dois 2 quero 2\" → pega o primeiro dígito isolado 0-3\nlet digitFound = null;\nfor (const msg of messages) {\n  const msgStr = (msg || '').toString();\n  // Regex: dígito 0-3 com espaço/começo/fim/pontuação ao redor\n  const match = msgStr.match(/(?:^|\\s|[^\\w])([0-3])(?:\\s|$|[^\\w])/);\n  if (match) {\n    digitFound = match[1];\n    break;\n  }\n  // Tenta também mensagem que SEJA só um dígito (sem separadores)\n  const trimmed = msgStr.trim().replace(/[.)\\s]/g, '');\n  if (/^[0-3]$/.test(trimmed)) {\n    digitFound = trimmed;\n    break;\n  }\n}\n\nconst finalContent = digitFound !== null ? digitFound : messages.join('\\n');\n\nreturn [{\n  json: {\n    contact_number: contactNumber,\n    content: finalContent,\n    message_id: messageId,\n    instance: instance,\n    debug_original_messages: messages,\n    debug_digit_found: digitFound\n  }\n}];\n"
      },
      "id": "b0000001-0000-0000-0000-000000000021",
      "name": "Filtrar input inteligente",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3500, 620]
    },
