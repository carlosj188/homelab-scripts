    {
      "parameters": {
        "jsCode": "// Debounce: adiciona mensagem ao buffer Redis e grava message_id como 'último'\n// Estrutura do buffer: JSON array de mensagens\n// TTL 30s (5s acima do debounce de 8s + margem)\n\nconst contactNumber = $('Normalizar campos').item.json.contact_number;\nconst messageId = $('Normalizar campos').item.json.message_id;\nconst content = $('Normalizar campos').item.json.content;\nconst instance = $('Normalizar campos').item.json.instance;\n\nreturn [{\n  json: {\n    contact_number: contactNumber,\n    message_id: messageId,\n    content: content,\n    instance: instance,\n    buffer_key: `buffer:msgs:${contactNumber}`,\n    last_key: `buffer:last:${contactNumber}`\n  }\n}];\n"
      },
      "id": "b0000001-0000-0000-0000-000000000013",
      "name": "Preparar buffer keys",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1740, 680]
    },
    {
      "parameters": {
        "operation": "push",
        "list": "={{ $json.buffer_key }}",
        "messageData": "={{ $json.content }}",
        "tail": true,
        "options": {}
      },
      "id": "b0000001-0000-0000-0000-000000000014",
      "name": "Redis: append buffer",
      "type": "n8n-nodes-base.redis",
      "typeVersion": 1,
      "position": [1960, 680],
      "credentials": {"redis": {"id": "YEun9v2RmIsI97HG", "name": "Redis account"}}
    },
    {
